Step0: Set working directory + read the counts/annotation table
setwd("/mmfs1/home/chandan.gautam/Lotus_Desq_FPKM")

suppressPackageStartupMessages({
  library(DESeq2)
  library(dplyr)
  library(tibble)
  library(ggplot2)
  library(ggrepel)
})

# Your file is TSV even though it's named .xls
counts_df <- read.delim(
  "gene_count.xls",
  header = TRUE,
  sep = "\t",
  stringsAsFactors = FALSE,
  check.names = FALSE
)

cat("Loaded:", nrow(counts_df), "rows x", ncol(counts_df), "cols\n")
print(colnames(counts_df))

Step1: Split into (A) count matrix and (B) annotation table
# sample columns (these are your 8 count columns)
sample_cols <- c("R7A_5","R7A_4","R7A_3","R7A_2",
                 "minSymICE_5","minSymICE_4","minSymICE_3","minSymICE_1")

stopifnot(all(sample_cols %in% colnames(counts_df)))

# annotation columns you want to keep in final table
ann_cols <- c("gene_id","gene_name","gene_chr","gene_start","gene_end",
              "gene_strand","gene_length","gene_biotype","gene_description","Family")

stopifnot(all(ann_cols %in% colnames(counts_df)))

# count matrix
count_mat <- counts_df %>%
  select(gene_id, all_of(sample_cols)) %>%
  mutate(gene_id = as.character(gene_id)) %>%
  column_to_rownames("gene_id") %>%
  as.matrix()

# DESeq2 needs integers
storage.mode(count_mat) <- "integer"

# annotation table (kept as separate table, later joined back)
ann_df <- counts_df %>%
  select(all_of(ann_cols)) %>%
  distinct(gene_id, .keep_all = TRUE) %>%
  mutate(
    gene_id = as.character(gene_id),
    gene_start = suppressWarnings(as.numeric(gene_start)),
    gene_end   = suppressWarnings(as.numeric(gene_end)),
    gene_length = suppressWarnings(as.numeric(gene_length))

  )

cat("Count matrix:", nrow(count_mat), "genes x", ncol(count_mat), "samples\n")
